{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "backups": {
          "$backupId": {
            ".validate": "newData.hasChildren(['userId', 'backupDateISO', 'backupData']) && newData.child('userId').val() == auth.uid"
          }
        }
      }
    }
  }
}
