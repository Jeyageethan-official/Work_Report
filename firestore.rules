rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /backups/{backupId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.backupData is map
          && request.resource.data.backupDateISO is string;
        allow update: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.backupData is map;
        allow delete: if isOwner(userId);
      }
    }

    match /public_shares/{shareId} {
      allow read: if resource.data.isPublic == true;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.type == 'monthly_report'
        && request.resource.data.isPublic == true;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
